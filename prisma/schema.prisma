// Privacy-first schema - minimal data storage
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// Core user record - name and email only
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())

  sessions         Session[]
  emailPreference  EmailPreference?
  emailLogs        EmailLog[]

  @@index([email])
}

// Track completion status only - no content storage
model Session {
  id          String    @id @default(cuid())
  userId      String
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  packetSent  Boolean   @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([completedAt])
}

// Email preferences and unsubscribe status
model EmailPreference {
  id           String   @id @default(cuid())
  userId       String   @unique
  frequency    String   @default("standard") // light, standard, intensive
  timezone     String   @default("America/Los_Angeles")
  unsubscribed Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Track what emails were sent - type only, no content
model EmailLog {
  id        String   @id @default(cuid())
  userId    String
  type      String   // packet, reminder_24h, reminder_weekly, reminder_inactive
  sentAt    DateTime @default(now())
  opened    Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sentAt])
  @@index([type, sentAt])
}

// Temporary storage for session data (auto-cleanup after 24h)
// This is for edge cases where user refreshes mid-session
model TempSessionData {
  id        String   @id @default(cuid())
  userId    String
  step      String
  data      String // JSON blob
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId, step])
  @@index([expiresAt])
}
